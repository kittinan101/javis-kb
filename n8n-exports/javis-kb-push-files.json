        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ sha: $json.sha, force: false }) }}"
      }
    },
    {
      "id": "7ee8b844-71d2-472c-86af-e38f9a7fa7a0",
      "name": "Sticky Note 2ebb10af",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        190,
        250
      ],
      "parameters": {
        "content": "## Javis KB - Push files (utility)\n\nPOST body: { message, files: [{ path, mode?, b64 | content }], base_tree? }\n\nDecodes base64 file contents, then commits ALL files as ONE commit on main via the Git Trees API (kittinan101/javis-kb).\n\nUses base_tree = current HEAD tree by default, so existing files are PRESERVED and only listed paths are added/updated. Pass body.base_tree to override (recovery).\n\nSafe: ref update uses force:false (fast-forward only).",
        "color": 4,
        "width": 1400,
        "height": 200
      }
    }
  ]
