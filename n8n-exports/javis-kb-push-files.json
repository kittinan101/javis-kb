    },
    {
      "id": "ee9b0610-0fd2-49cd-b852-0e903f9f2955",
      "name": "Build Tree Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const body = $('Webhook').first().json.body;\nconst parentSha = $json.commit.sha;\nconst parentTreeSha = $json.commit.commit.tree.sha;\nif (!body || !Array.isArray(body.files) || body.files.length === 0) {\n  throw new Error('webhook body.files is required (array of {path, mode?, b64|content})');\n}\nconst tree = body.files.map(f => ({\n  path: f.path,\n  mode: f.mode || '100644',\n  type: 'blob',\n  content: f.b64 ? Buffer.from(f.b64, 'base64').toString('utf8') : (f.content || '')\n}));\n// base_tree keeps all existing files; only listed paths are added/updated.\n// body.base_tree may override (e.g. recovery from a bad commit).\nreturn [{ json: {\n  parentSha,\n  treeBody: JSON.stringify({ base_tree: body.base_tree || parentTreeSha, tree }),\n  message: body.message || 'chore: update kb',\n  fileCount: tree.length\n} }];"
      }
    },
    {
      "id": "83d39351-0d8a-4dbb-8ba0-8f1b33eaba77",
      "name": "Create Tree",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        900,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/kittinan101/javis-kb/git/trees",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $json.treeBody }}"
      }
    },
    {
      "id": "ff05f6c0-9c7d-42e1-bba0-fee93f68bb5f",
      "name": "Create Commit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1120,
