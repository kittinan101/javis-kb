        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ message: $('Build Tree Payload').first().json.message, tree: $json.sha, parents: [$('Build Tree Payload').first().json.parentSha] }) }}"
      }
    },
    {
      "id": "6ed5d448-b08f-4bd5-a3e7-9288ea90f00c",
